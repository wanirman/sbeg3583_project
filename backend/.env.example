# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# CORS allowlist — comma-separated origins, or * for any (default).
# Production example: CORS_ORIGIN=https://biodiv.wanirman.dev
CORS_ORIGIN=*

# MongoDB (single database for everything)
MONGO_URI=mongodb://127.0.0.1:27017/biodiversity_pwa

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# iNaturalist computer-vision token (optional, for photo ID)
INAT_API_TOKEN=

# iNaturalist OAuth (auto-refreshing photo-ID token).
# Preferred: run scripts/inat-setup.js to obtain INAT_ACCESS_TOKEN (no password stored)
INAT_ACCESS_TOKEN=
# Register an app at https://www.inaturalist.org/oauth/applications
INAT_APP_ID=
INAT_APP_SECRET=
INAT_USERNAME=
INAT_PASSWORD=
